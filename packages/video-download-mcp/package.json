{
  "name": "@cory-ronghua/video-fetch-mcp",
  "version": "1.0.1",
  "description": "MCP server for downloading videos from social/video platforms",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "video-fetch-mcp": "dist/mcp-bin.js",
    "video-fetch-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "node dist/cli.js",
    "serve": "node dist/index.js",
    "serve:tsx": "tsx src/index.ts",
    "test": "vitest",
    "prepack": "npm run build",
    "release:check": "npm pack --dry-run"
  },
  "keywords": [
    "video",
    "download",
    "mcp",
    "douyin",
    "xiaohongshu",
    "bilibili",
    "youtube"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "playwright-core": "^1.40.0",
    "axios": "^1.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
